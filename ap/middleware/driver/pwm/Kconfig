menu "PWM"
	config PWM
		bool "Enable pwm"
		default y

	choice PWM_VERSION
		prompt "ASIC PWM IP Version"
		default PWM_V0P0

		config PWM_V0P0
			bool "PWM_V0P0"
			help
			    ASIC PWM IP Version V0P0:BK7256XX,BK7251XX,the chips MP before 2023-04

		config PWM_V1PX
			bool "PWM_V1PX"
			help
			    "ASIC PWM IP Version V1P1:BK7236XX...,the chips MP after 2023-04"
	endchoice

	config PWM_HAS_TWO_INT
		bool "Enable pwm has two int"
		default n

	config PWM_PM_CB_SUPPORT
		bool "PWM PM Support"
		default n

	config PWM_PHASE_SHIFT
		bool "PWM phase shift Support"
		default n

	config PWM_API_TEST
		bool "Enable pwm api test"
		default n
		help
			Enable pwm api test.

	config PWM_USE_DEFAULT_GPIO_MAP
		bool "Use default GPIO map from gpio_map.h"
		default y
		help
			If set to y, use default GPIO_PWM_MAP_TABLE from gpio_map.h.
			If set to n, define GPIO_PWM_MAP_TABLE in usr_gpio_cfg.h.

endmenu

